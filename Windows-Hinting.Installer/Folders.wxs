<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Windows-Hinting">
        <Directory Id="RuntimesFolder" Name="runtimes">
          <Directory Id="RuntimesWinFolder" Name="win">
            <Directory Id="RuntimesWinLibFolder" Name="lib">
              <Directory Id="RuntimesWinLibNet80Folder" Name="net8.0" />
            </Directory>
          </Directory>
          <Directory Id="RuntimesBrowserFolder" Name="browser">
            <Directory Id="RuntimesBrowserLibFolder" Name="lib">
              <Directory Id="RuntimesBrowserLibNet80Folder" Name="net8.0" />
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Windows-Hinting" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />
  </Fragment>
</Wix>
